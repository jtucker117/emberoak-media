# ---- Cloudinary (your single account) ----
CLOUDINARY_CLOUD_NAME=wrjc0nyq
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret   # keep secret — server-only, never in the website

# ---- Auth ----
SESSION_SECRET=paste_a_long_random_string_here

# ---- Studio owner login(s) for managing the public portfolio ----
# JSON array. Use "password" for quick start, or "passwordHash" (npm run hash "pw") for security.
CLIENTS_JSON=[{"slug":"emberoak","name":"Ember & Oak","folder":"emberoak","password":"change-me"}]

# ---- Client delivery galleries (full-res downloads for the studio's clients) ----
# If ALLOW_OPEN_DELIVERIES=true, any folder deliveries/<code> opens by its code (no pin).
# For pin-protected or titled galleries, list them here:
GALLERIES_JSON=[{"code":"smith-wedding","title":"Smith Wedding","pin":"1234","folder":"deliveries/smith-wedding"}]
ALLOW_OPEN_DELIVERIES=true
DELIVERIES_ROOT=deliveries

# ---- CORS: which site origins may call this API (use * if the site is served by this same app) ----
ALLOWED_ORIGINS=*
